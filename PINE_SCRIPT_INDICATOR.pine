// ============================================================
// OptionFlow Key Levels — by rikoinvestfg
// Gamma Flip | Max Pain | Call Wall | Put Wall
// Alertas inteligentes de confluencia alcista/bajista
// Data from OptionFlow Dashboard — update inputs from dashboard
// Compatible: TradingView Premium — ANY timeframe
// ============================================================
//@version=6
indicator(title="OptionFlow Key Levels", shorttitle="OFL", overlay=true, max_lines_count=10, max_labels_count=50)

// ─────────────────────────────────────────────
// INPUTS — Key Levels (actualizar desde el dashboard)
// ─────────────────────────────────────────────
// Abre el dashboard, copia los niveles de tu ticker y pegalos aqui.
// Estos valores se actualizan automaticamente por el dashboard cada 5 min.

gamma_flip_val = input.float(0, "Gamma Flip",  group="🔑 Key Levels — Copiar del Dashboard", tooltip="Nivel Gamma Flip del dashboard")
max_pain_val   = input.float(0, "Max Pain",    group="🔑 Key Levels — Copiar del Dashboard", tooltip="Nivel Max Pain del dashboard")
call_wall_val  = input.float(0, "Call Wall",   group="🔑 Key Levels — Copiar del Dashboard", tooltip="Nivel Call Wall del dashboard")
put_wall_val   = input.float(0, "Put Wall",    group="🔑 Key Levels — Copiar del Dashboard", tooltip="Nivel Put Wall del dashboard")

// ─────────────────────────────────────────────
// INPUTS — Visual
// ─────────────────────────────────────────────
show_gamma_flip  = input.bool(true,  "Mostrar Gamma Flip",  group="Niveles")
show_max_pain    = input.bool(true,  "Mostrar Max Pain",    group="Niveles")
show_call_wall   = input.bool(true,  "Mostrar Call Wall",   group="Niveles")
show_put_wall    = input.bool(true,  "Mostrar Put Wall",    group="Niveles")
show_table       = input.bool(true,  "Mostrar Tabla",       group="Tabla")
table_position   = input.string("top_right", "Posicion Tabla", options=["top_right","top_left","bottom_right","bottom_left"], group="Tabla")
col_gamma_flip   = input.color(color.new(#FF9800, 0), "Color Gamma Flip", group="Colores")
col_max_pain     = input.color(color.new(#E91E63, 0), "Color Max Pain",   group="Colores")
col_call_wall    = input.color(color.new(#00BCD4, 0), "Color Call Wall",  group="Colores")
col_put_wall     = input.color(color.new(#F44336, 0), "Color Put Wall",   group="Colores")
line_width       = input.int(2, "Grosor de Lineas", minval=1, maxval=4, group="Estilo")
line_style_input = input.string("solid", "Estilo de Linea", options=["solid","dashed","dotted"], group="Estilo")
conf_pct         = input.float(0.3, "Proximidad a nivel (%)", minval=0.05, maxval=2.0, step=0.05, group="Confluencia")

// ─────────────────────────────────────────────
// CONVERT INPUTS TO SERIES (na if 0)
// ─────────────────────────────────────────────
gamma_flip = gamma_flip_val > 0 ? gamma_flip_val : na
max_pain   = max_pain_val   > 0 ? max_pain_val   : na
call_wall  = call_wall_val  > 0 ? call_wall_val  : na
put_wall   = put_wall_val   > 0 ? put_wall_val   : na

sym = syminfo.ticker

// ─────────────────────────────────────────────
// LOGICA DE CONFLUENCIA
// ─────────────────────────────────────────────
pct = conf_pct / 100

above_gamma     = not na(gamma_flip) and close > gamma_flip
below_gamma     = not na(gamma_flip) and close < gamma_flip
near_gamma_flip = not na(gamma_flip) and math.abs(close - gamma_flip) / gamma_flip <= pct
near_put_wall   = not na(put_wall)   and math.abs(close - put_wall)   / put_wall   <= pct
near_call_wall  = not na(call_wall)  and math.abs(close - call_wall)  / call_wall  <= pct

bull_score = (above_gamma ? 1 : 0) + (near_put_wall and above_gamma ? 1 : 0) + (not na(max_pain) and close > max_pain ? 1 : 0) + (near_gamma_flip and above_gamma ? 1 : 0)
bear_score = (below_gamma ? 1 : 0) + (near_call_wall and below_gamma ? 1 : 0) + (not na(max_pain) and close < max_pain ? 1 : 0) + (near_gamma_flip and below_gamma ? 1 : 0)

bull_signal  = bull_score >= 3
bear_signal  = bear_score >= 3
bull_trigger = bull_signal and not bull_signal[1]
bear_trigger = bear_signal and not bear_signal[1]

cross_above_gf  = ta.crossover(close,  gamma_flip)
cross_below_gf  = ta.crossunder(close, gamma_flip)
bounce_put_wall  = not na(put_wall)  and low  <= put_wall  * (1 + pct) and close > open
reject_call_wall = not na(call_wall) and high >= call_wall * (1 - pct) and close < open

// ─────────────────────────────────────────────
// SEÑALES VISUALES
// ─────────────────────────────────────────────
plotshape(bull_trigger,    title="Confluencia Alcista",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.small,  text="BULL", textcolor=color.lime)
plotshape(bear_trigger,    title="Confluencia Bajista",  style=shape.triangledown, location=location.abovebar, color=color.new(color.red,  0), size=size.small,  text="BEAR", textcolor=color.red)
plotshape(cross_above_gf,  title="Cruce GF Arriba",      style=shape.circle,       location=location.belowbar, color=color.new(#FF9800,    0), size=size.tiny,   text="GF+",  textcolor=#FF9800)
plotshape(cross_below_gf,  title="Cruce GF Abajo",       style=shape.circle,       location=location.abovebar, color=color.new(#FF9800,    0), size=size.tiny,   text="GF-",  textcolor=#FF9800)
plotshape(bounce_put_wall, title="Rebote Put Wall",      style=shape.labelup,      location=location.belowbar, color=color.new(color.green,30), size=size.tiny, text="PW",   textcolor=color.white)
plotshape(reject_call_wall,title="Rechazo Call Wall",    style=shape.labeldown,    location=location.abovebar, color=color.new(color.blue, 30), size=size.tiny, text="CW",   textcolor=color.white)

// ─────────────────────────────────────────────
// LINEAS HORIZONTALES
// ─────────────────────────────────────────────
line_style = line_style_input == "dashed" ? line.style_dashed : line_style_input == "dotted" ? line.style_dotted : line.style_solid

var line ln_gf = na
var line ln_mp = na
var line ln_cw = na
var line ln_pw = na

if barstate.islast
    if not na(ln_gf)
        line.delete(ln_gf)
    if not na(ln_mp)
        line.delete(ln_mp)
    if not na(ln_cw)
        line.delete(ln_cw)
    if not na(ln_pw)
        line.delete(ln_pw)

    bar_start = bar_index - 50

    if show_gamma_flip and not na(gamma_flip)
        ln_gf := line.new(bar_start, gamma_flip, bar_index + 20, gamma_flip, color=col_gamma_flip, width=line_width, style=line_style, extend=extend.right)
        label.new(bar_index + 5, gamma_flip, "GF " + str.tostring(gamma_flip, "#.##"), color=color.new(col_gamma_flip, 85), textcolor=col_gamma_flip, style=label.style_label_left, size=size.small)

    if show_max_pain and not na(max_pain)
        ln_mp := line.new(bar_start, max_pain, bar_index + 20, max_pain, color=col_max_pain, width=line_width, style=line_style, extend=extend.right)
        label.new(bar_index + 5, max_pain, "MP " + str.tostring(max_pain, "#.##"), color=color.new(col_max_pain, 85), textcolor=col_max_pain, style=label.style_label_left, size=size.small)

    if show_call_wall and not na(call_wall)
        ln_cw := line.new(bar_start, call_wall, bar_index + 20, call_wall, color=col_call_wall, width=line_width, style=line_style, extend=extend.right)
        label.new(bar_index + 5, call_wall, "CW " + str.tostring(call_wall, "#.##"), color=color.new(col_call_wall, 85), textcolor=col_call_wall, style=label.style_label_left, size=size.small)

    if show_put_wall and not na(put_wall)
        ln_pw := line.new(bar_start, put_wall, bar_index + 20, put_wall, color=col_put_wall, width=line_width, style=line_style, extend=extend.right)
        label.new(bar_index + 5, put_wall, "PW " + str.tostring(put_wall, "#.##"), color=color.new(col_put_wall, 85), textcolor=col_put_wall, style=label.style_label_left, size=size.small)

// ─────────────────────────────────────────────
// TABLA
// ─────────────────────────────────────────────
tbl_pos = table_position == "top_right" ? position.top_right : table_position == "top_left" ? position.top_left : table_position == "bottom_right" ? position.bottom_right : position.bottom_left

var table tbl = na

if barstate.islast and show_table
    if not na(tbl)
        table.delete(tbl)

    tbl := table.new(tbl_pos, 2, 8, bgcolor=color.new(#0D1117, 10), border_color=color.new(#30363D, 0), border_width=1, frame_color=color.new(#30363D, 0), frame_width=1)

    table.cell(tbl, 0, 0, "OptionFlow Levels", text_color=color.white,            bgcolor=color.new(#161B22, 0), text_size=size.small, text_halign=text.align_center)
    table.cell(tbl, 1, 0, sym,                 text_color=color.new(#58A6FF, 0),  bgcolor=color.new(#161B22, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 1, "Gamma Flip",        text_color=color.new(#8B949E, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 1, not na(gamma_flip) ? str.tostring(gamma_flip, "#.##") : "-", text_color=col_gamma_flip, bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 2, "Max Pain",          text_color=color.new(#8B949E, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 2, not na(max_pain)   ? str.tostring(max_pain,   "#.##") : "-", text_color=col_max_pain,   bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 3, "Call Wall",         text_color=color.new(#8B949E, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 3, not na(call_wall)  ? str.tostring(call_wall,  "#.##") : "-", text_color=col_call_wall,  bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 4, "Put Wall",          text_color=color.new(#8B949E, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 4, not na(put_wall)   ? str.tostring(put_wall,   "#.##") : "-", text_color=col_put_wall,   bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 5, "---",               text_color=color.new(#30363D, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.tiny)
    table.cell(tbl, 1, 5, "---",               text_color=color.new(#30363D, 0),  bgcolor=color.new(#0D1117, 0), text_size=size.tiny)

    bias_label = bull_signal ? "ALCISTA" : bear_signal ? "BAJISTA" : above_gamma ? "Neutral+" : "Neutral-"
    bias_color = bull_signal ? color.lime : bear_signal ? color.red : above_gamma ? color.new(color.green, 40) : color.new(color.red, 40)
    score_val  = bull_signal ? bull_score : bear_score

    table.cell(tbl, 0, 6, "Bias",  text_color=color.new(#8B949E, 0), bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 6, bias_label, text_color=bias_color,         bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 7, "Score", text_color=color.new(#8B949E, 0), bgcolor=color.new(#0D1117, 0), text_size=size.small)
    table.cell(tbl, 1, 7, str.tostring(score_val) + "/4", text_color=bias_color, bgcolor=color.new(#0D1117, 0), text_size=size.small, text_halign=text.align_right)

// ─────────────────────────────────────────────
// FONDO
// ─────────────────────────────────────────────
bg_color = not na(gamma_flip) and close > gamma_flip ? color.new(color.green, 96) : not na(gamma_flip) and close < gamma_flip ? color.new(color.red, 96) : na
bgcolor(bg_color, title="Zona Gamma Flip")

// ─────────────────────────────────────────────
// ALERTAS — strings constantes (requerido Pine v6)
// ─────────────────────────────────────────────
alertcondition(bull_trigger,    "CONFLUENCIA ALCISTA",     "ALCISTA {{ticker}} a {{close}} — Confluencia bullish 3+ niveles activa")
alertcondition(bear_trigger,    "CONFLUENCIA BAJISTA",     "BAJISTA {{ticker}} a {{close}} — Confluencia bearish 3+ niveles activa")
alertcondition(cross_above_gf,  "Rompe Gamma Flip Arriba", "{{ticker}} ROMPE Gamma Flip al ALZA en {{close}} — Dealers compran dips")
alertcondition(cross_below_gf,  "Rompe Gamma Flip Abajo",  "{{ticker}} ROMPE Gamma Flip a la BAJA en {{close}} — Dealers venden rallies")
alertcondition(bounce_put_wall, "Rebote en Put Wall",      "{{ticker}} REBOTA en Put Wall en {{close}} — posible alza")
alertcondition(reject_call_wall,"Rechazo en Call Wall",    "{{ticker}} RECHAZA en Call Wall en {{close}} — posible baja")
alertcondition(ta.cross(close, max_pain), "Cruce Max Pain","{{ticker}} cruzo Max Pain en {{close}}")
